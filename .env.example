# ==================== 数据库 ====================
DATABASE_URL="postgresql://sentinel:sentinel_pwd@localhost:5432/sentinel_db?schema=public"
REDIS_URL="redis://localhost:6379"

# ==================== JWT 认证 ====================
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# ==================== 管理员 ====================
ADMIN_EMAIL="admin@sentinel.aags.app"
ADMIN_PASSWORD="change-this-password"

# ==================== LLM API Keys (管理后台也可配置) ====================
PERPLEXITY_API_KEY=""
DEEPSEEK_API_KEY=""
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# ==================== 加密 ====================
ENCRYPTION_KEY="32-byte-hex-key-for-aes-encryption"

# ==================== 应用 ====================
NODE_ENV="development"
PORT=3001
WEB_URL="http://localhost:3003"
API_URL="http://localhost:3001"
