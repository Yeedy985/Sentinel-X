{
  "name": "sentinel-service",
  "version": "1.0.0",
  "private": true,
  "description": "AlphaSentinel 公共扫描服务 — 后端API + 主页 + 管理后台",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "db:generate": "pnpm --filter @sentinel/db generate",
    "db:push": "pnpm --filter @sentinel/db push",
    "db:migrate": "pnpm --filter @sentinel/db migrate",
    "db:seed": "pnpm --filter @sentinel/db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
